# Option A (recommended): single connection string
# DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/postgres



# Option B: separate PG* variables
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=YOUR_PASSWORD
# PGDATABASE=postgres

PORT=3000

# SerpApi key (DO NOT commit your real key in .env)
# SERPAPI_KEY=your_serpapi_key_here
